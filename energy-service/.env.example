# Application
APP_NAME="Energy Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001
APP_TIMEZONE=Europe/London

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=energy_service
DB_USERNAME=sail
DB_PASSWORD=password

# Cache / Queue
CACHE_STORE=redis
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PORT=6379

# ─── SolaxCloud API (v2) ──────────────────────────────────────────────────────
# Inverter: SolaX X1-HYBRID-6.0-D (6kW)
#
# SOLAX_TOKEN_ID — from SolaxCloud portal → Service → API → tokenId
# This is placed in the HTTP Header on every request (not query string).
#
# SOLAX_WIFI_SN — the Wi-Fi dongle serial number (wifiSn in the API).
# This is NOT the inverter serial number. Find it on the dongle label
# or in SolaxCloud portal → Device Management.
SOLAX_TOKEN_ID=
SOLAX_WIFI_SN=
SOLAX_BASE_URL=https://global.solaxcloud.com

# ─── Octopus Energy API ───────────────────────────────────────────────────────
# Tariff: Intelligent Octopus Go
# Auth: HTTP Basic — API key as username, empty password.
# Keys available at: octopus.energy/dashboard/developer
OCTOPUS_API_KEY=
OCTOPUS_ACCOUNT_NUMBER=
OCTOPUS_MPAN=
OCTOPUS_SERIAL_NUMBER=
OCTOPUS_BASE_URL=https://api.octopus.energy

# Tariff rates (pence per kWh) — update if your rates change
OCTOPUS_CHEAP_RATE_PENCE=7.5
OCTOPUS_DAY_RATE_PENCE=24.0
OCTOPUS_CHEAP_START=23:30
OCTOPUS_CHEAP_END=05:30

# ─── Battery ──────────────────────────────────────────────────────────────────
# SolaX T-BAT H 5.8 x2 = 11.6kWh total capacity
# Usable = 70% of total (longevity ceiling, not a technical limit)
BATTERY_TOTAL_CAPACITY_KWH=11.6
BATTERY_USABLE_CAPACITY_KWH=8.1
BATTERY_CHARGE_CEILING_PCT=70
BATTERY_CHARGE_RATE_KW=3.5

# ─── Solar installation ───────────────────────────────────────────────────────
# Location: Nailsworth, Gloucestershire
SOLAR_LATITUDE=51.7
SOLAR_LONGITUDE=-2.2
# Group 5 azimuth is TBC — update when orientation is confirmed
SOLAR_GROUP5_AZIMUTH=181

# ─── Forecast.solar ───────────────────────────────────────────────────────────
# No API key required for the free tier (12 req/hour).

# ─── Open-Meteo ───────────────────────────────────────────────────────────────
# No API key required.
