# Application
APP_NAME="Energy BFF"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8002
APP_TIMEZONE=Europe/London

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database (BFF owns its own DB for user/session storage)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=energy_bff
DB_USERNAME=sail
DB_PASSWORD=password

# Cache / Queue
CACHE_STORE=redis
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Auth (Laravel Sanctum SPA) ───────────────────────────────────────────────
# Comma-separated list of frontend domains that can issue Sanctum session cookies
SANCTUM_STATEFUL_DOMAINS=localhost:3000
FRONTEND_URL=http://localhost:3000
SESSION_DOMAIN=localhost

# ─── Upstream service ─────────────────────────────────────────────────────────
# Internal Docker network URL — do not change unless you rename the service
ENERGY_SERVICE_URL=http://energy-service:8000
ENERGY_SERVICE_TIMEOUT=10
