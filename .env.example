# =============================================================================
# Solar Energy Optimisation — root .env
# Copy this file to .env and fill in the values marked with <...>
# This file is read by docker-compose; never commit .env to version control.
# =============================================================================

# ─── Laravel app keys ─────────────────────────────────────────────────────────
# Generate with: php -r "echo 'base64:' . base64_encode(random_bytes(32)) . PHP_EOL;"
ENERGY_SERVICE_APP_KEY=
ENERGY_BFF_APP_KEY=

# ─── MySQL ────────────────────────────────────────────────────────────────────
# Root password is only used by MySQL internally.
# Sail user/password are used by both Laravel services.
MYSQL_ROOT_PASSWORD=root_password
MYSQL_USER=sail
MYSQL_PASSWORD=password

# ─── SolaxCloud API (v2) ──────────────────────────────────────────────────────
# SOLAX_TOKEN_ID  — SolaxCloud portal → Service → API → tokenId
# SOLAX_WIFI_SN   — Wi-Fi dongle serial (NOT the inverter serial)
#                   Found on the dongle label or in Device Management
SOLAX_TOKEN_ID=
SOLAX_WIFI_SN=
SOLAX_BASE_URL=https://global.solaxcloud.com

# ─── Octopus Energy API ───────────────────────────────────────────────────────
# API key available at: octopus.energy/dashboard/developer
OCTOPUS_API_KEY=
OCTOPUS_ACCOUNT_NUMBER=
OCTOPUS_MPAN=
OCTOPUS_SERIAL_NUMBER=
OCTOPUS_BASE_URL=https://api.octopus.energy

# Tariff: Intelligent Octopus Go (pence per kWh — update if rates change)
OCTOPUS_CHEAP_RATE_PENCE=7.5
OCTOPUS_DAY_RATE_PENCE=24.0
OCTOPUS_CHEAP_START=23:30
OCTOPUS_CHEAP_END=05:30

# ─── Battery ──────────────────────────────────────────────────────────────────
# SolaX T-BAT H 5.8 x2 = 11.6kWh total; 70% ceiling for longevity
BATTERY_TOTAL_CAPACITY_KWH=11.6
BATTERY_USABLE_CAPACITY_KWH=8.1
BATTERY_CHARGE_CEILING_PCT=70
BATTERY_CHARGE_RATE_KW=3.5

# ─── Solar installation ───────────────────────────────────────────────────────
# Location: Nailsworth, Gloucestershire
SOLAR_LATITUDE=51.7
SOLAR_LONGITUDE=-2.2
# Group 5 azimuth is TBC — update when orientation is confirmed
SOLAR_GROUP5_AZIMUTH=181
